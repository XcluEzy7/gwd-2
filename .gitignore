# ── IDE/Editor ──
.idea/
.vscode/
*.code-workspace

.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ── Dependencies ──
node_modules/

# ── Build outputs ──
dist/
build/
dist-test/
target/
!/pkg/dist/modes/
!/pkg/dist/core/export-html/
packages/*/dist/

# ── TypeScript ──
*.tsbuildinfo
*.tgz

# ── Environment & Secrets ──
.env
.env.*
!.env.example

# ── Python ──
__pycache__/
*.pyc
.venv/
venv/

# ── Node/JS ──
.next/
coverage/
.cache/
tmp/
*.log

# ── Compiled output in src/ (should only contain .ts source) ──
src/**/*.js
src/**/*.js.map
src/**/*.d.ts
src/**/*.d.ts.map
!src/**/*.test.js

# ── Workspace packages ──
packages/*/dist/
packages/*/node_modules/

# ── Scratch/WIP files ──
preflight-script.ts

# ── Stale lock files (npm is canonical) ──
package-lock.json
pnpm-lock.yaml
bun.lock

# ── Vendor directories ──
vendor/
!packages/pi-coding-agent/src/core/export-html/vendor/
!pkg/dist/core/export-html/vendor/

# ── Pi/GSD tooling (development-only) ──
.claude/
.pi-lens/
.plans/
.planning/
.gsd/
.gsd*.tgz
.artifacts/
.bg_shell
.bg-shell/
AGENTS.md
RELEASE-GUIDE.md
TODOS.md
.audits/
docs/coherence-audit/

# ── Studio/Electron (if used) ──
studio/out/
studio/release/
studio/dist/
*.dmg
*.AppImage
*.snap

# ── GSD baseline (auto-generated) ──
.gsd
.gsd-id
